# ============================================================
# FILE: .env
# PURPOSE: Store secret credentials here ONLY.
#          This file should NEVER be pushed to GitHub.
#          Add ".env" to your .gitignore file!
# ============================================================

# Your AWS Access Key ID (like a username for AWS programmatic access)
# Get this from: AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=AKIAUFM6Z26JY4VBKP4C

# Your AWS Secret Access Key (like a password — keep this private!)
AWS_SECRET_ACCESS_KEY=OPeYTQIr+2TXsa/331x6LBsVFwun79aXO9Xw+nuk

# The AWS region your services are deployed in
AWS_DEFAULT_REGION=us-east-1

# NOTE: On EC2 with an IAM Role attached, you do NOT need these keys.
# The EC2 instance automatically gets credentials from the IAM Role.
# These keys are only needed for local development on your laptop.